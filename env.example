# Get key: https://platform.openai.com/api-keys  then run: npm run setup:openai
OPENAI_API_KEY=
DATABASE_URL=postgresql://japandi:japandi@localhost:5432/japandi
OUTPUT_DIR=./outputs

# Article pipeline (Medium <-> note draft studio)
# Random string protecting POST /api/cron/pipeline (e.g. `openssl rand -hex 24`)
CRON_SECRET=
# Optional: model for article drafts (default gpt-4o)
# ARTICLE_MODEL=gpt-4o
# Optional: image model for posters (default gpt-image-1; e.g. dall-e-3 to fall back)
# POSTER_IMAGE_MODEL=gpt-image-1
# Optional: gpt-image-1 quality (low | medium | high | auto; default high)
# POSTER_IMAGE_QUALITY=high
# Optional: print upscale factor for posters (default 4 -> ~4096x6144)
# UPSCALE_SCALE=4

# YouTube channel research (overseas trend research + original channel ideation)
# Get key: https://console.cloud.google.com/apis/credentials (enable "YouTube Data API v3")
YOUTUBE_API_KEY=
# Optional: comma-separated ISO region codes to poll (default US,GB,IN,JP,KR,TW)
# YOUTUBE_REGIONS=US,GB,IN,JP,KR,TW
# Optional: model for AI channel-idea proposals (default gpt-4o)
# CHANNEL_IDEA_MODEL=gpt-4o

# Optional: auto-push OPENAI_API_KEY to Render after deploy
# RENDER_API_KEY=rnd_...
# RENDER_SERVICE_NAME=japandi-poster-studio

# Local DB: docker compose up -d
# Render: DATABASE_URL is set automatically from Postgres addon
