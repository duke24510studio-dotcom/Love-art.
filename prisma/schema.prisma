generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PosterTheme {
  id             String   @id @default(cuid())
  collection     String
  themeJa        String
  themeEn        String
  verticalTextJa String
  subtitleEn     String
  motif          String
  colorPalette   String
  stylePreset    String   @default("")
  status         String   @default("idea")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  generations PosterGeneration[]
}

model PosterGeneration {
  id                String   @id @default(cuid())
  themeId           String
  orientation       String   @default("portrait")
  prompt            String   @default("")
  imagePath         String   @default("")
  printImagePath    String   @default("")
  imageUrl          String   @default("")
  qualityScore      Int?
  qualityComment    String   @default("")
  etsyTitle         String   @default("")
  etsyDescription   String   @default("")
  etsyTags          String   @default("")
  pinterestCaption  String   @default("")
  instagramCaption  String   @default("")
  xCaption          String   @default("")
  status            String   @default("idea")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  theme PosterTheme @relation(fields: [themeId], references: [id], onDelete: Cascade)
}

// --- Article pipeline (Medium <-> note original-article studio) ---

// RSS/Atom feeds polled for trends. Used for inspiration only, never reposted.
model FeedSource {
  id            String    @id @default(cuid())
  name          String
  feedUrl       String    @unique
  // "en2ja" (Medium EN -> note JA) or "ja2en" (note/JP -> Medium EN)
  direction     String
  category      String    @default("")
  active        Boolean   @default(true)
  lastFetchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items ResearchItem[]
}

// A trend item collected from a feed. Inspiration source; body is NOT stored.
model ResearchItem {
  id          String    @id @default(cuid())
  feedId      String?
  direction   String
  category    String    @default("")
  title       String
  url         String    @unique
  summary     String    @default("")
  author      String    @default("")
  publishedAt DateTime?
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  feed     FeedSource? @relation(fields: [feedId], references: [id], onDelete: SetNull)
  articles Article[]
}

// A generated ORIGINAL draft. Never a copy/translation of a source article.
model Article {
  id             String   @id @default(cuid())
  researchItemId String?
  direction      String
  category       String   @default("")
  // Output language: "ja" (note) or "en" (medium)
  language       String
  targetPlatform String   @default("")
  topic          String   @default("")
  title          String   @default("")
  subtitle       String   @default("")
  body           String   @default("")
  tags           String   @default("")
  model          String   @default("")
  status         String   @default("generated")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  researchItem ResearchItem? @relation(fields: [researchItemId], references: [id], onDelete: SetNull)
}

// --- YouTube channel research (overseas trend research + original channel ideation) ---
// Data comes ONLY from the official YouTube Data API v3 (trending charts + public
// stats). Used for market research and as INSPIRATION for original channel concepts —
// never to copy titles/thumbnails/content or to impersonate an existing channel.
// See docs/YOUTUBE_RESEARCH.md.

// One polling snapshot of a trending video in a given region. History accumulates
// across runs so "early velocity" (views-per-hour) and rank changes can be tracked.
model YtVideoSnapshot {
  id           String    @id @default(cuid())
  videoId      String
  regionCode   String    @default("ALL")
  title        String
  channelId    String
  channelTitle String
  categoryId   String    @default("")
  publishedAt  DateTime?
  viewCount    Int       @default(0)
  likeCount    Int       @default(0)
  commentCount Int       @default(0)
  durationSec  Int       @default(0)
  thumbnailUrl String    @default("")
  tags         String    @default("")
  vph          Float     @default(0)
  fetchedAt    DateTime  @default(now())
  createdAt    DateTime  @default(now())

  ideas ChannelIdea[]

  @@index([videoId])
  @@index([regionCode, fetchedAt])
  @@index([channelId])
}

// One polling snapshot of a channel's public stats. Compared across time to
// surface rapidly-growing channels (subscriber/view delta per day).
model YtChannelSnapshot {
  id              String   @id @default(cuid())
  channelId       String
  title           String
  country         String   @default("")
  subscriberCount Int      @default(0)
  viewCount       Float    @default(0)
  videoCount      Int      @default(0)
  thumbnailUrl    String   @default("")
  fetchedAt       DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([channelId, fetchedAt])
}

// An AI-proposed ORIGINAL channel concept, using a trending video/channel only as
// inspiration for format and niche. Never reproduces the source's name, titles,
// thumbnails, or content. Human-reviewed; no auto-upload/auto-post exists.
model ChannelIdea {
  id              String   @id @default(cuid())
  sourceVideoId   String?
  sourceChannelId String   @default("")
  sourceRegion    String   @default("")
  niche           String   @default("")
  channelName     String   @default("")
  concept         String   @default("")
  targetAudience  String   @default("")
  contentPillars  String   @default("")
  sampleTitles    String   @default("")
  postingCadence  String   @default("")
  notes           String   @default("")
  model           String   @default("")
  status          String   @default("idea")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sourceVideo YtVideoSnapshot? @relation(fields: [sourceVideoId], references: [id], onDelete: SetNull)
}
