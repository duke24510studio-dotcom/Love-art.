generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PosterTheme {
  id             String   @id @default(cuid())
  collection     String
  themeJa        String
  themeEn        String
  verticalTextJa String
  subtitleEn     String
  motif          String
  colorPalette   String
  stylePreset    String   @default("")
  status         String   @default("idea")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  generations PosterGeneration[]
}

model PosterGeneration {
  id                String   @id @default(cuid())
  themeId           String
  orientation       String   @default("portrait")
  prompt            String   @default("")
  imagePath         String   @default("")
  printImagePath    String   @default("")
  imageUrl          String   @default("")
  qualityScore      Int?
  qualityComment    String   @default("")
  etsyTitle         String   @default("")
  etsyDescription   String   @default("")
  etsyTags          String   @default("")
  pinterestCaption  String   @default("")
  instagramCaption  String   @default("")
  xCaption          String   @default("")
  status            String   @default("idea")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  theme PosterTheme @relation(fields: [themeId], references: [id], onDelete: Cascade)
}

// --- Article pipeline (Medium <-> note original-article studio) ---

// RSS/Atom feeds polled for trends. Used for inspiration only, never reposted.
model FeedSource {
  id            String    @id @default(cuid())
  name          String
  feedUrl       String    @unique
  // "en2ja" (Medium EN -> note JA) or "ja2en" (note/JP -> Medium EN)
  direction     String
  category      String    @default("")
  active        Boolean   @default(true)
  lastFetchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items ResearchItem[]
}

// A trend item collected from a feed. Inspiration source; body is NOT stored.
model ResearchItem {
  id          String    @id @default(cuid())
  feedId      String?
  direction   String
  category    String    @default("")
  title       String
  url         String    @unique
  summary     String    @default("")
  author      String    @default("")
  publishedAt DateTime?
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  feed     FeedSource? @relation(fields: [feedId], references: [id], onDelete: SetNull)
  articles Article[]
}

// A generated ORIGINAL draft. Never a copy/translation of a source article.
model Article {
  id             String   @id @default(cuid())
  researchItemId String?
  direction      String
  category       String   @default("")
  // Output language: "ja" (note) or "en" (medium)
  language       String
  targetPlatform String   @default("")
  topic          String   @default("")
  title          String   @default("")
  subtitle       String   @default("")
  body           String   @default("")
  tags           String   @default("")
  model          String   @default("")
  status         String   @default("generated")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  researchItem ResearchItem? @relation(fields: [researchItemId], references: [id], onDelete: SetNull)
}

// --- Rakuten affiliate review studio ---
// One tracked Rakuten product at a time accumulates weekly "review rounds":
// 5 fixed reviewer-persona write-ups + one AI lifestyle photo per round.
// Builds a growing library of affiliate review content per product instead of
// generating many products at once. Publishing stays human-reviewed.

// A Rakuten Ichiba product being tracked for weekly review generation.
model RakutenProduct {
  id            String   @id @default(cuid())
  itemUrl       String   @unique
  itemCode      String   @default("")
  shopCode      String   @default("")
  shopName      String   @default("")
  name          String   @default("")
  price         Int      @default(0)
  imageUrl      String   @default("")
  catchcopy     String   @default("")
  itemCaption   String   @default("")
  genreName     String   @default("")
  reviewAverage Float    @default(0)
  reviewCount   Int      @default(0)
  affiliateUrl  String   @default("")
  // "active" (weekly cron keeps generating rounds) | "paused" | "archived"
  status        String   @default("active")
  weekCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rounds ReviewRound[]
}

// One weekly batch of reviews for a product: a shared AI lifestyle photo
// plus 5 persona reviews (see ReviewRound.reviews).
model ReviewRound {
  id         String   @id @default(cuid())
  productId  String
  weekNumber Int
  imagePath  String   @default("")
  // "generated" -> "review" -> "approved" / "rejected" -> "exported"
  status     String   @default("generated")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product RakutenProduct  @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviews ProductReview[]
}

// One reviewer-persona's write-up within a ReviewRound.
model ProductReview {
  id         String   @id @default(cuid())
  roundId    String
  persona    String
  personaJa  String   @default("")
  angle      String   @default("")
  title      String   @default("")
  body       String   @default("")
  rating     Int      @default(5)
  snsCaption String   @default("")
  status     String   @default("generated")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  round ReviewRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
}
